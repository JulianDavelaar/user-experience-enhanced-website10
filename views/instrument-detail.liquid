{% render 'partials/header.liquid' %}

<main class="pagina detail-pagina">
  <section class="detail">
      <img src="https://fdnd-agency.directus.app/assets/{{ instrument.photo | width_url: width: '473x314' }}"  alt="{{ instrument.name }}" class="detail-foto" type="image/avif">
  

    <div class="instrument-info">
      <h1>{{ instrument.name }}</h1>
      <p id="instrument-status">
        Status:
        {% if instrument.status.name %}
          {{ instrument.status.name }}
        {% elsif instrument.status %}
          {{ instrument.status }}
        {% else %}
          Beschikbaar
        {% endif %}
      </p>
      {% if instrument.student_name %}
      <p>Huurder: {{ instrument.student_name }}</p>
      {% endif %}
    </div>
  </section>

  <form class="uitlenen-form" action="/instrument/{{ instrument.id }}/uitlenen" method="post">
   
    <section class="opmerking">
      <label for="huurder">Huurder:</label>
      <input id="huurder" name="huurder" type="text" required>

      <label for="accessoires">Accessoires:</label>
      <input id="accessoires" name="accessoires" type="text">

      <label for="opmerking">Opmerkingen:</label>
      <div class="opmerking-grid">
       <textarea id="opmerking" name="opmerking">{{ instrument.details }}</textarea>
    </section>

    <button class="knop-uitlenen" type="submit" {% if instrument.status == "Uitgeleend" or instrument.status.name == "Uitgeleend" %}disabled{% endif %}>
      <span class="knop-tekst"> Uitlenen </span>
      <span class="spinner"></span>
      <span class="checkmark"></span>
    </button>

    <button class="knop-uitlenen" type="submit" 
      formaction="/instrument/{{ instrument.id }}/innemen"
      formnovalidate
      {% if instrument.status == "Beschikbaar" or instrument.status.name == "Beschikbaar" %}disabled{% endif %}>
      <span class="knop-tekst">Innemen</span>
      <span class="spinner"></span>
      <span class="checkmark"></span>
    </button>
   </div>
  </form>
</main>

{% render 'partials/footer.liquid'%}



<script>
  

// loading & succes state
const uitleenForm = document.querySelector(".uitlenen-form")
const statusElement = document.querySelector("#instrument-status")

uitleenForm.addEventListener("submit", async function(event) {
  //voorkom de standaard submit van de browser
  event.preventDefault()

  const geklikteKnop = event.submitter
  const knopTekstElement = geklikteKnop.querySelector(".knop-tekst")
  const submitURL = geklikteKnop.formAction || uitleenForm.action


  geklikteKnop.classList.add("loading")
  knopTekstElement.textContent = "laden..."

  let formulierData = new FormData(uitleenForm);

  // Data fetchen:
  // Doe een fetch naar de server net als hoe browsers dit normaal doen
  // gebruik daarvoor het action en method attribuut van het formulier
  // stuur de formulierelementen mee
  const serverAntwoord = await fetch(submitURL, {
    method: uitleenForm.method, //POST dus
    body: new URLSearchParams(formulierData) // << dit moet omdat server.js ander niet met de formulier data kan werken
  })


  // Data verwerken: 
  // De server geeft data terug als het posten goed gaat
  const antwoordHTML = await serverAntwoord.text()

  // Normaal zou de browser die HTML parsen en weergeven,
  // parse de nieuwe HTML en maak hiervan een nieuw Document Object Model in het geheugen
  const parser = new DOMParser()
  const nieuweDOM = parser.parseFromString(antwoordHTML, 'text/html')

  //Zoek in die nieuwe HTML DOM onze nieuwe UI state op, die we via liquid hebben klaargezet
  const nieuweStatus = nieuweDOM.querySelector('#instrument-status')

  //Data van de server toevoegen aan de DOM,
  //overschrijf de HTML met de nieuwe HTML
  statusElement.innerHTML = nieuweStatus.innerHTML


  //loading state verwijderen na fetch
  geklikteKnop.classList.remove("loading")

  // succes state laten zien
  const bestaandeMelding = document.querySelector(".succes-melding")
  if (bestaandeMelding) bestaandeMelding.remove()

  const isInnemen = submitURL.includes('innemen')
  const succesMelding = document.createElement("p")
  succesMelding.textContent = isInnemen
  ? 'instrument succesvol ingenomen'
  : 'instrument succesvol uitgeleend'
  succesMelding.classList.add("succes-melding")
  uitleenForm.insertAdjacentElement("afterend", succesMelding)

  uitleenForm.querySelectorAll("button").forEach(knop => knop.disabled = false)
  geklikteKnop.disabled = true
})

</script>